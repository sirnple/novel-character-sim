{
  "name": "create-project",
  "description": "Create a new Railway project",
  "inputSchema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Name for the new project"
      },
      "description": {
        "type": "string",
        "description": "Optional project description"
      },
      "workspaceId": {
        "type": "string",
        "description": "Workspace ID to create the project in. If omitted, uses the first available workspace."
      },
      "isPublic": {
        "type": "boolean",
        "description": "Whether the project should be public (default: false)"
      }
    },
    "required": [
      "name"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}