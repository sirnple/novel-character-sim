{
  "name": "list-deployments",
  "description": "List recent deployments for a Railway project, optionally filtered by environment, service, or status. Returns the most recent first.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "projectId": {
        "type": "string",
        "description": "The project ID"
      },
      "environmentId": {
        "type": "string",
        "description": "Filter to a specific environment"
      },
      "serviceId": {
        "type": "string",
        "description": "Filter to a specific service"
      },
      "status": {
        "type": "string",
        "enum": [
          "WAITING",
          "NEEDS_APPROVAL",
          "QUEUED",
          "INITIALIZING",
          "SKIPPED",
          "BUILDING",
          "DEPLOYING",
          "SUCCESS",
          "FAILED",
          "REMOVED",
          "CRASHED",
          "REMOVING",
          "SLEEPING"
        ],
        "description": "Filter to deployments with this status (e.g. SUCCESS, FAILED, CRASHED, BUILDING, DEPLOYING)"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "description": "Max deployments to return (default 10, max 50)"
      }
    },
    "required": [
      "projectId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}