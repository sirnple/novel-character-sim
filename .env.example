LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_ANALYSIS_MODEL=deepseek-v4-flash
DEEPSEEK_WRITE_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional: OpenCode Go gateway (same model env keys as above)
# LLM_PROVIDER=opencode-go
# DEEPSEEK_API_KEY=...   # OpenCode key from https://opencode.ai/auth
# Optional override: OPENCODE_API_KEY=...  OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Optional: for Claude or OpenAI
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Admin (/admin) — required in all environments
ADMIN_PASSWORD=

