# === App LLM config (canonical) ===
# provider: claude | openai | deepseek | opencode-go
LLM_PROVIDER=opencode-go

# API key for the active provider (preferred over provider-specific keys)
LLM_API_KEY=sk-your-key-here

# Role models (analysis = 分析提取; write = 续写/agent)
LLM_ANALYSIS_MODEL=deepseek-v4-flash
LLM_WRITE_MODEL=deepseek-v4-pro
# Optional single fallback model id
# LLM_MODEL=deepseek-v4-flash

# Optional OpenAI-compatible base URL (defaults per provider)
# OpenCode Go: https://opencode.ai/zen/go/v1
# DeepSeek direct: https://api.deepseek.com/v1
# LLM_BASE_URL=https://opencode.ai/zen/go/v1

LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# --- Legacy / provider-specific (optional; only if not using LLM_API_KEY) ---
# OPENCODE_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# Admin (/admin) — required
ADMIN_PASSWORD=

# --- Database ---
# App default: data/novels.db
# Eval scripts call useEvalDb() → data/eval/novels.db (isolated; do not point this at main for npm run eval:*)
# NCS_DB_PATH=data/novels.db
# NOVEL_DB_PATH=  # alias of NCS_DB_PATH
